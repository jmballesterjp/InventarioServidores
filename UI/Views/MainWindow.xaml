<!-- MainWindow.xaml -->
<!-- Interfaz principal del sistema de inventario -->
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventario de Servidores - v1.0" 
        Height="600" 
        Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Window.Resources>
        <!-- Estilos reutilizables -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#b3b3b3"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#b3b3b3"/>
                    <Setter Property="Foreground" Value="#808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#b3b3b3"/>
                    <Setter Property="Foreground" Value="#808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Header -->
            <RowDefinition Height="Auto"/>     <!-- Toolbar -->
            <RowDefinition Height="*"/>        <!-- DataGrid -->
            <RowDefinition Height="Auto"/>     <!-- Button Bar -->
            <RowDefinition Height="Auto"/>     <!-- StatusBar -->
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📊 " FontSize="24"/>
            <TextBlock Text="Inventario de Servidores" 
                      Style="{StaticResource HeaderTextStyle}"
                      FontSize="24"
                      VerticalAlignment="Center"/>
        </StackPanel>
        
        <!-- TOOLBAR -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Name="btnRefresh" 
                    Content="🔄 Refrescar Vista" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,10,0"/>
            
            <Button Name="btnUpdateSelected" 
                    Content="⚡ Actualizar Seleccionado" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"
                    IsEnabled="False"/>

            <Button Name="btnUpdateAll" 
                    Content="🔄 Actualizar Todos" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"/>

            <Button Name="btnViewDetails"
                Content="👁️ Ver detalles"
                Style="{StaticResource PrimaryButtonStyle}"
                Margin="0,0,10,0"
                IsEnabled="False"/>
            
            <Separator Width="1" Margin="10,0" Background="#DDDDDD"/>
            
            <TextBlock Text="🔍" 
                      FontSize="16" 
                      VerticalAlignment="Center" 
                      Margin="10,0,5,0"/>
            <TextBox Name="txtSearch" 
                    Width="200" 
                    Height="30"
                    VerticalContentAlignment="Center"
                    Padding="5"
                    FontSize="13"/>
            
            <Button Name="btnSearch" 
                    Content="Buscar" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="5,0,0,0"
                    Padding="10,5"/>
        </StackPanel>
        
        <!-- DATAGRID -->
        <DataGrid Grid.Row="2" 
                  Name="dgServers"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9F9F9"
                  RowHeight="35"
                  FontSize="12">
            
            <DataGrid.Columns>
                <!-- Servidor -->
                <DataGridTextColumn Header="Servidor" 
                                   Binding="{Binding ServerName}" 
                                   Width="170">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <!--Setter Property="Foreground" Value="#1976D2"/--> <!-- Problemas con el backgroundcolor de selección -->
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <!-- IP -->
                <DataGridTextColumn Header="Dirección IP" 
                                   Binding="{Binding IPAddressFormatted}" 
                                   Width="120"/>
                
                <!-- Sistema Operativo -->
                <DataGridTextColumn Header="Sistema Operativo" 
                                   Binding="{Binding OSName}" 
                                   Width="240"/>
                
                <!-- RAM -->
                <DataGridTextColumn Header="RAM" 
                                   Binding="{Binding RAMFormatted}" 
                                   Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <!-- Uptime -->
                <DataGridTextColumn Header="Uptime (días)" 
                                   Binding="{Binding UptimeDays}" 
                                   Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <!-- Última actualización -->
                <DataGridTextColumn Header="Última Actualización" 
                                   Binding="{Binding LastInventoryFormatted}" 
                                   Width="150"/>
                
                <!-- Estado -->
                <DataGridTemplateColumn Header="Estado" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusColor}" 
                                   CornerRadius="3" 
                                   Padding="5,3"
                                   HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" 
                                          Foreground="White" 
                                          FontWeight="Bold"
                                          FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- BUTTON BAR -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Name="btnAddServer" 
                    Content="➕ Añadir nuevo servidor" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,0,0"/>
        </StackPanel>
        
        <!-- STATUSBAR -->
        <Border Grid.Row="4" 
                Background="#EEEEEE" 
                Padding="10"
                Margin="0,15,0,0"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Name="txtStatus" 
                              Text="Listo" 
                              FontSize="12"
                              Foreground="#666666"
                              VerticalAlignment="Center"/>
                    
                    <TextBlock Text=" | " 
                              Margin="10,0"
                              Foreground="#CCCCCC"/>
                    
                    <TextBlock Name="txtServerCount" 
                              Text="Servidores: 0" 
                              FontSize="12"
                              Foreground="#666666"
                              VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" 
                          Name="txtLastUpdate" 
                          Text="Sin actualizaciones" 
                          FontSize="11"
                          Foreground="#999999"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
